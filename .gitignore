# ============================================================
# Next.js + Prisma + TypeScript — .gitignore
# ============================================================

# ────────────────────────────────────────────────────────────
# Dependencies
# ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ────────────────────────────────────────────────────────────
# Next.js build output
# ────────────────────────────────────────────────────────────
/.next/
/out/
/build

# ────────────────────────────────────────────────────────────
# Prisma generated client
# ────────────────────────────────────────────────────────────
/src/generated/prisma
/prisma/*.db
/prisma/*.db-journal

# ────────────────────────────────────────────────────────────
# Environment & secrets  ← NEVER commit these
# ────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.template

# ────────────────────────────────────────────────────────────
# TypeScript
# ────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ────────────────────────────────────────────────────────────
# Testing & coverage
# ────────────────────────────────────────────────────────────
/coverage
/.nyc_output

# ────────────────────────────────────────────────────────────
# Debug & log files
# ────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ────────────────────────────────────────────────────────────
# Vercel / deployment
# ────────────────────────────────────────────────────────────
.vercel

# ────────────────────────────────────────────────────────────
# OS generated files
# ────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ────────────────────────────────────────────────────────────
# Editor / IDE files
# ────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ────────────────────────────────────────────────────────────
# Certificates & keys
# ────────────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx

# ────────────────────────────────────────────────────────────
# Sensitive / personal documents  ← keep off version control
# ────────────────────────────────────────────────────────────
*.doc
*.docx
*.pdf
*.xls
*.xlsx

# ────────────────────────────────────────────────────────────
# Misc scratch / temp files
# ────────────────────────────────────────────────────────────
check-enum.ts
test-status.ts
walkthrough.md
